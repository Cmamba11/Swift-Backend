{
  "name": "swift-plastics-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "ts-node-esm server.ts",
     "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "db:push": "npx prisma db push",
    "db:generate": "npx prisma generate",
    "db:seed": "ts-node-esm prisma/seed.ts",
    "db:seed:reset": "SEED_RESET=1 ts-node-esm prisma/seed.ts"
  },
  "prisma": {
    "seed": "ts-node-esm prisma/seed.ts"
  },
  "dependencies": {
    "@jridgewell/trace-mapping": "^0.3.31",
    "@prisma/adapter-pg": "latest",
    "@prisma/client": "latest",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pg": "^8.11.5",
    "prisma": "^7.4.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.7",
    "@types/pg": "^8.11.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": "20.x"
  }
}
